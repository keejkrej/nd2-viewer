{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "dependencies": [
    "itk",
    {
      "name": "qtbase",
      "default-features": false,
      "features": [
        "concurrent",
        "gui",
        "opengl",
        "widgets"
      ],
      "platform": "!linux"
    },
    {
      "name": "qtbase",
      "default-features": false,
      "features": [
        "concurrent",
        "fontconfig",
        "freetype",
        "gui",
        "harfbuzz",
        "opengl",
        "widgets",
        "xcb",
        "xcb-sm",
        "xcb-xlib",
        "xrender"
      ],
      "platform": "linux"
    },
    "qtmultimedia",
    "qtsvg",
    "onnxruntime",
    {
      "name": "vtk",
      "default-features": false,
      "features": ["qt", "opengl"]
    },
    "libczi"
  ]
}
